# =============================================================================
# Manual AWS login and tunnel commands
# =============================================================================
# Copy this file to .env and edit values.
# Note: these commands are STORED here for convenience, but are not auto-executed.

AWS_SSO_LOGIN_CMD=aws sso login --sso-session infoblox

AWS_SSM_CMD_DATA_ANALYST_DEV=aws ssm --profile data-analyst-dev --region us-east-1 start-session --target i-0e8761941fc57c652 --document-name AWS-StartPortForwardingSession --parameters portNumber=54391,localPortNumber=54391
AWS_SSM_CMD_DATA_QA_DEV=aws ssm --profile data-qa-dev --region us-east-1 start-session --target i-0e8761941fc57c652 --document-name AWS-StartPortForwardingSession --parameters portNumber=54391,localPortNumber=54391
AWS_SSM_CMD_DATA_ANALYST_PREPROD=aws ssm --profile data-analyst-preprod --region us-east-1 start-session --target i-0b5ced4784159a9be --document-name AWS-StartPortForwardingSession --parameters portNumber=54392,localPortNumber=54392

# =============================================================================
# Select default Redshift environment
# =============================================================================
# This can be overridden with --env in scripts.
REDSHIFT_ENV=data_analyst_dev

# =============================================================================
# Redshift environment: DATA_ANALYST_DEV
# =============================================================================
REDSHIFT_HOST_DATA_ANALYST_DEV=localhost
REDSHIFT_PORT_DATA_ANALYST_DEV=54391
REDSHIFT_DB_DATA_ANALYST_DEV=your_database
REDSHIFT_USER_DATA_ANALYST_DEV=your_username
REDSHIFT_PASSWORD_DATA_ANALYST_DEV=your_password
REDSHIFT_SCHEMA_DATA_ANALYST_DEV=public

# =============================================================================
# Redshift environment: DATA_QA_DEV
# =============================================================================
REDSHIFT_HOST_DATA_QA_DEV=localhost
REDSHIFT_PORT_DATA_QA_DEV=54391
REDSHIFT_DB_DATA_QA_DEV=your_database
REDSHIFT_USER_DATA_QA_DEV=your_username
REDSHIFT_PASSWORD_DATA_QA_DEV=your_password
REDSHIFT_SCHEMA_DATA_QA_DEV=public

# =============================================================================
# Redshift environment: DATA_ANALYST_PREPROD
# =============================================================================
REDSHIFT_HOST_DATA_ANALYST_PREPROD=localhost
REDSHIFT_PORT_DATA_ANALYST_PREPROD=54392
REDSHIFT_DB_DATA_ANALYST_PREPROD=your_database
REDSHIFT_USER_DATA_ANALYST_PREPROD=your_username
REDSHIFT_PASSWORD_DATA_ANALYST_PREPROD=your_password
REDSHIFT_SCHEMA_DATA_ANALYST_PREPROD=public

# =============================================================================
# S3 defaults (optional)
# =============================================================================
AWS_REGION=us-east-1
AWS_PROFILE=
S3_DEFAULT_BUCKET=your-bucket
S3_DEFAULT_PREFIX=your/path/
DEFAULT_ROW_LIMIT=100
