commands:
  - name: sso_login
    description: AWS SSO login session
    command: aws sso login --sso-session infoblox

  - name: ssm_data_analyst_dev
    description: Start SSM port forwarding for data_analyst_dev
    command: aws ssm --profile data-analyst-dev --region us-east-1 start-session --target i-0e8761941fc57c652 --document-name AWS-StartPortForwardingSession --parameters portNumber=54391,localPortNumber=54391

  - name: ssm_data_qa_dev
    description: Start SSM port forwarding for data_qa_dev
    command: aws ssm --profile data-qa-dev --region us-east-1 start-session --target i-0e8761941fc57c652 --document-name AWS-StartPortForwardingSession --parameters portNumber=54391,localPortNumber=54391

  - name: ssm_data_analyst_preprod
    description: Start SSM port forwarding for data_analyst_preprod
    command: aws ssm --profile data-analyst-preprod --region us-east-1 start-session --target i-0b5ced4784159a9be --document-name AWS-StartPortForwardingSession --parameters portNumber=54392,localPortNumber=54392
